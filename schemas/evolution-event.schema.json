{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evolution-event.schema.json",
  "title": "Evolution Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "timestamp",
    "source_run",
    "evidence_refs",
    "trigger",
    "problem_detected",
    "previous_workflow",
    "change_made",
    "affected_assets",
    "writeback_target",
    "reason",
    "score_before",
    "score_after",
    "sensitive_data_review",
    "next_validator",
    "status"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "source_run": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "trigger": {
      "type": "string",
      "minLength": 1
    },
    "problem_detected": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "previous_workflow": {
      "type": "array",
      "items": {}
    },
    "change_made": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "affected_assets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "writeback_target": {
      "type": "string",
      "enum": [
        "evolution",
        "workflow-kb/failure-cases",
        "workflow-kb/composition-patterns",
        "workflow-kb/verified-workflows",
        "verified-recipes",
        "blocked"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "score_before": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "score_after": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "sensitive_data_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "notes"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_reviewed", "passed", "blocked"]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "next_validator": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    }
  }
}
