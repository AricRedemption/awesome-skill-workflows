{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "action-verification.schema.json",
  "title": "Action Verification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "scenario_id",
    "action_type",
    "requested_mode",
    "approved_mode",
    "allowed_action",
    "target_artifact",
    "verification_level",
    "fact_status",
    "compliance_status",
    "promotion_status",
    "gate_order",
    "gates",
    "evidence_refs"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "scenario_id": { "type": "string", "minLength": 1 },
    "action_type": { "type": "string", "minLength": 1 },
    "requested_mode": { "type": "string", "minLength": 1 },
    "approved_mode": { "type": "string", "minLength": 1 },
    "allowed_action": { "type": "string", "minLength": 1 },
    "target_artifact": { "type": "string", "minLength": 1 },
    "verification_level": {
      "type": "string",
      "enum": [
        "action_blocked",
        "action_attempted",
        "action_fact_verified",
        "action_compliance_verified",
        "failed_with_evidence"
      ]
    },
    "fact_status": {
      "type": "string",
      "enum": [
        "not_attempted",
        "attempted",
        "fact_observed",
        "fact_verified"
      ]
    },
    "compliance_status": {
      "type": "string",
      "enum": ["not_applicable", "failed", "passed"]
    },
    "promotion_status": {
      "type": "string",
      "enum": [
        "not_promotable",
        "promotable_for_scope",
        "promoted"
      ]
    },
    "action_started_at": { "type": "string" },
    "action_finished_at": { "type": "string" },
    "gate_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "human_review",
          "risk_approval",
          "state_precheck",
          "mode_approval",
          "action_handoff",
          "action_execution",
          "proof_verification",
          "promotion_approval"
        ]
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_review",
        "risk_approval",
        "state_precheck",
        "mode_approval",
        "action_handoff",
        "action_execution",
        "proof_verification",
        "promotion_approval"
      ],
      "properties": {
        "human_review": { "$ref": "#/$defs/gate" },
        "risk_approval": { "$ref": "#/$defs/gate" },
        "state_precheck": { "$ref": "#/$defs/gate" },
        "mode_approval": { "$ref": "#/$defs/gate" },
        "action_handoff": { "$ref": "#/$defs/gate" },
        "action_execution": { "$ref": "#/$defs/gate" },
        "proof_verification": { "$ref": "#/$defs/gate" },
        "promotion_approval": { "$ref": "#/$defs/gate" }
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checked_at", "evidence_ref", "notes"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "blocked", "not_applicable"]
        },
        "checked_at": { "type": "string", "minLength": 1 },
        "evidence_ref": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    }
  }
}
