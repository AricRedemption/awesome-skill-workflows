{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "multi-agent-skill-workflow.schema.json",
  "title": "MultiAgentSkillWorkflow",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "workflow_type",
    "goal",
    "roles",
    "nodes",
    "review_gate",
    "writeback",
    "success_criteria"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_type": {
      "type": "string",
      "enum": [
        "multi_agent_skill_workflow"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "enum": [
        "single_problem"
      ]
    },
    "backend_hint": {
      "type": "string",
      "minLength": 1
    },
    "roles": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/role"
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "review_gate": {
      "$ref": "#/$defs/review_gate"
    },
    "writeback": {
      "$ref": "#/$defs/writeback"
    },
    "terminal_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "passed",
          "revision_required",
          "blocked",
          "failed"
        ]
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role_id",
        "purpose",
        "skill_refs"
      ],
      "properties": {
        "role_id": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "skill_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "optional": {
          "type": "boolean"
        }
      }
    },
    "review_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "reviewer_role_id",
        "verifier_role_id"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "hard"
          ]
        },
        "reviewer_role_id": {
          "type": "string",
          "minLength": 1
        },
        "verifier_role_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "writeback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_terminal_states",
        "knowledge_targets"
      ],
      "properties": {
        "allowed_terminal_states": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "passed",
              "revision_required",
              "blocked",
              "failed"
            ]
          }
        },
        "knowledge_targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "node_type"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "node_type": {
          "type": "string",
          "enum": [
            "spawn",
            "sequence",
            "fork",
            "join",
            "loop"
          ]
        },
        "role_id": {
          "type": "string",
          "minLength": 1
        },
        "skill_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "handoff_contract": {
          "type": "string",
          "minLength": 1
        },
        "evidence_required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "gate_effect": {
          "type": "string",
          "minLength": 1
        },
        "run_mode_effect": {
          "type": "string",
          "minLength": 1
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        },
        "branches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        },
        "body": {
          "$ref": "#/$defs/node"
        },
        "loop_cap": {
          "type": "integer",
          "minimum": 1
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0
        },
        "join_strategy": {
          "type": "string",
          "minLength": 1
        },
        "continue_when": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
