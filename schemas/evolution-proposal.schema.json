{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evolution-proposal.schema.json",
  "title": "Evolution Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proposal_id",
    "status",
    "signature",
    "target_file",
    "trigger_type",
    "confidence",
    "why_this_matters",
    "evidence_refs",
    "duplicate_check",
    "proposed_change",
    "apply_plan",
    "validation_plan"
  ],
  "properties": {
    "proposal_id": {
      "type": "string",
      "pattern": "^evo-[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9-]+$"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "approved", "rejected"]
    },
    "signature": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "target_file": {
      "type": "string",
      "minLength": 1
    },
    "trigger_type": {
      "type": "string",
      "enum": ["correction", "preference", "workflow", "struggle"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "why_this_matters": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "duplicate_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checked", "result", "decision"],
      "properties": {
        "checked": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "result": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": ["create", "update-existing-draft", "skip"]
        }
      }
    },
    "proposed_change": {
      "type": "string",
      "minLength": 1
    },
    "apply_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
