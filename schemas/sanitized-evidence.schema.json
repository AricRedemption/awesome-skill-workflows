{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sanitized-evidence.schema.json",
  "title": "Sanitized Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "source_run",
    "evidence_refs",
    "sensitive_data_status",
    "redaction_notes",
    "allowed_for_promotion"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "source_run": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sensitive_data_status": {
      "type": "string",
      "enum": [
        "not_reviewed",
        "sanitized",
        "contains_sensitive_local_state",
        "blocked"
      ]
    },
    "redaction_notes": {
      "type": "string"
    },
    "allowed_for_promotion": {
      "type": "boolean"
    }
  }
}
