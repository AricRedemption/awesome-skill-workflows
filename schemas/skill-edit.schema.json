{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-edit.schema.json",
  "title": "Skill Optimization Edit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "edit_id",
    "operation",
    "target_section",
    "rationale",
    "before",
    "after",
    "evidence_refs",
    "risk_impact"
  ],
  "properties": {
    "edit_id": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "type": "string",
      "enum": ["add", "delete", "replace"]
    },
    "target_section": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "before": {
      "type": "string"
    },
    "after": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risk_impact": {
      "type": "string",
      "enum": ["none", "reduces_risk", "increases_risk", "unknown"]
    }
  }
}
