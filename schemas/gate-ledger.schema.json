{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gate-ledger.schema.json",
  "title": "Gate Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "scenario",
    "publish_mode",
    "content_artifact",
    "gate_order",
    "gates",
    "final_verdict"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "scenario": {
      "type": "string",
      "minLength": 1
    },
    "publish_mode": {
      "type": "string",
      "enum": [
        "content_package_only",
        "human_review_then_draft",
        "human_review_then_publish"
      ]
    },
    "content_artifact": {
      "type": "string",
      "minLength": 1
    },
    "gate_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "quality_score",
          "human_review",
          "risk_approval",
          "account_state",
          "mode_approval",
          "platform_handoff",
          "proof_verification",
          "recipe_promotion"
        ]
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quality_score",
        "human_review",
        "risk_approval",
        "account_state",
        "mode_approval",
        "platform_handoff",
        "proof_verification",
        "recipe_promotion"
      ],
      "properties": {
        "quality_score": {
          "$ref": "#/$defs/gate"
        },
        "human_review": {
          "$ref": "#/$defs/gate"
        },
        "risk_approval": {
          "$ref": "#/$defs/gate"
        },
        "account_state": {
          "$ref": "#/$defs/gate"
        },
        "mode_approval": {
          "$ref": "#/$defs/gate"
        },
        "platform_handoff": {
          "$ref": "#/$defs/gate"
        },
        "proof_verification": {
          "$ref": "#/$defs/gate"
        },
        "recipe_promotion": {
          "$ref": "#/$defs/gate"
        }
      }
    },
    "final_verdict": {
      "type": "string",
      "enum": ["passed", "failed", "blocked"]
    }
  },
  "$defs": {
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "checked_at",
        "evidence_ref",
        "notes"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "blocked", "not_applicable"]
        },
        "checked_at": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
